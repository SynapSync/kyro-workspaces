# Data source toggle
# true  → uses mock data from lib/services/mock/
# false → uses file-based data from KYRO_WORKSPACE_PATH
NEXT_PUBLIC_USE_MOCK_DATA=true

# Optional: artificial delay in ms for mock services (simulates network latency)
NEXT_PUBLIC_MOCK_DELAY_MS=0

# Real API base URL — leave empty while using mock data
NEXT_PUBLIC_API_URL=

# Workspace root path — directory where markdown files live on disk
# Agents and the UI read/write from this directory
# See FILE-FORMAT-SPEC.md for the expected directory structure
KYRO_WORKSPACE_PATH=/Users/your-user/kyro-workspace
